    "呼吸与冥想": {
      "label_en": "Breathing & Mindfulness",
      "activities": [
        {
          "id": "m01",
          "text": "做5分钟的呼吸冥想",
          "duration": 5
        },
        {
          "id": "m02",
          "text": "5分钟练习「54321法」：找5样看到的、4样摸到的、3样听到的、2样闻到的、1样尝到的",
          "duration": 5
        },
        {
          "id": "m03",
          "text": "闭眼配合缓慢呼吸，什么都不想",
          "duration": 5
        },
        {
          "id": "m04",
          "text": "在心里默默祈祷，平安幸福",
          "duration": 3
        },
        {
          "id": "m05",
          "text": "生理叹气：连续两次吸气，再缓慢呼出，重复5次",
          "duration": 3
        },
        {
          "id": "m06",
          "text": "4-7-8呼吸法：吸气4秒，屏住7秒，呼出8秒，重复4次",
          "duration": 5
        },
        {
          "id": "m07",
          "text": "Box breathing：吸气4秒→屏住4秒→呼出4秒→屏住4秒，重复4次",
          "duration": 5
        },
        {
          "id": "m08",
          "text": "渐进式肌肉放松：从脚趾开始，依次绷紧再放松每个部位",
          "duration": 8
        },
        {
          "id": "m09",
          "text": "打开邮件前先做三次深呼吸：慢慢吸气→屏住→缓慢呼出，让肩膀放松",
          "duration": 2
        },
        {
          "id": "m10",
          "text": "慢慢洗一次手，感受水温、皂香和水声，把它当作一个小仪式",
          "duration": 3
        },
        {
          "id": "m11",
          "text": "标记脑子里的想法类型：在计划、在担心、在评判——只是观察，不评价（认知解离练习）",
          "duration": 5
        },
        {
          "id": "m12",
          "text": "把手放在胸口，感受心跳或呼吸的起伏，提醒自己此刻是安全的",
          "duration": 3
        },
        {
          "id": "m13",
          "text": "在心里重复一句平静的话，比如此刻已经足够，或吸入平静、呼出担忧",
          "duration": 3
        },
        {
          "id": "m14",
          "text": "环顾四周，找出所有同一种颜色的东西，把空间变成一场正念寻宝",
          "duration": 3
        },
        {
          "id": "m15",
          "text": "坐着什么都不做5分钟：不看手机，不听东西，就让自己静静存在",
          "duration": 5
        },
        {
          "id": "m16",
          "text": "正念刷牙：专注感受牙刷的触感、牙膏的味道，完全投入这一分钟",
          "duration": 3
        }
      ]
    },
